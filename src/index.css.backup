@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 0 0% 100%;
    --foreground: 222.2 84% 4.9%;
    --card: 0 0% 100%;
    --card-foreground: 222.2 84% 4.9%;
    --popover: 0 0% 100%;
    --popover-foreground: 222.2 84% 4.9%;
    --primary: 221.2 83.2% 53.3%;
    --primary-foreground: 210 40% 98%;
    --secondary: 210 40% 96.1%;
    --secondary-foreground: 222.2 47.4% 11.2%;
    --muted: 210 40% 96.1%;
    --muted-foreground: 215.4 16.3% 46.9%;
    --accent: 210 40% 96.1%;
    --accent-foreground: 222.2 47.4% 11.2%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 210 40% 98%;
    --border: 214.3 31.8% 91.4%;
    --input: 214.3 31.8% 91.4%;
    --ring: 221.2 83.2% 53.3%;
    --radius: 0.5rem;
  }

  .dark {
    --background: 222.2 84% 4.9%;
    --foreground: 210 40% 98%;
    --card: 222.2 84% 4.9%;
    --card-foreground: 210 40% 98%;
    --popover: 222.2 84% 4.9%;
    --popover-foreground: 210 40% 98%;
    --primary: 217.2 91.2% 59.8%;
    --primary-foreground: 222.2 47.4% 11.2%;
    --secondary: 217.2 32.6% 17.5%;
    --secondary-foreground: 210 40% 98%;
    --muted: 217.2 32.6% 17.5%;
    --muted-foreground: 215 20.2% 65.1%;
    --accent: 217.2 32.6% 17.5%;
    --accent-foreground: 210 40% 98%;
    --destructive: 0 62.8% 30.6%;
    --destructive-foreground: 210 40% 98%;
    --border: 217.2 32.6% 17.5%;
    --input: 217.2 32.6% 17.5%;
    --ring: 224.3 76.3% 48%;
  }
}

@layer base {
  * {
    border-color: hsl(var(--border));
  }
  body {
    background-color: #0a0a0b;
    color: #ffffff;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }
}

@layer components {
  /* Glass Card Effect */
  .glass-card {
    @apply bg-glass-white backdrop-blur-md border border-glass-border rounded-lg shadow-lg transition-all duration-300;
  }
  
  .glass-card:hover {
    @apply border-neon-blue shadow-glow-blue;
  }

  /* Cyber Buttons */
  .btn-cyber-blue {
    @apply bg-gradient-to-r from-neon-blue to-neon-blue-dark text-cyber-black font-bold px-6 py-3 rounded-lg shadow-glow-blue hover:shadow-glow-blue transition-all duration-300 hover:scale-105;
  }

  .btn-cyber-green {
    @apply bg-gradient-to-r from-neon-green to-neon-green-dark text-cyber-black font-bold px-6 py-3 rounded-lg shadow-glow-green hover:shadow-glow-green transition-all duration-300 hover:scale-105;
  }

  /* Stat Cards with Glow */
  .stat-card-blue {
    @apply glass-card border-neon-blue/30 hover:shadow-glow-blue;
  }

  .stat-card-green {
    @apply glass-card border-neon-green/30 hover:shadow-glow-green;
  }

  .stat-card-purple {
    @apply glass-card border-neon-purple/30 hover:shadow-glow-purple;
  }

  .stat-card-orange {
    @apply glass-card border-neon-orange/30 hover:shadow-glow-orange;
  }

  /* Neon Text */
  .text-neon-glow {
    @apply text-neon-blue;
    text-shadow: 0 0 10px rgba(0, 212, 255, 0.8);
  }

  /* Badge Variants */
  .badge-cyber {
    @apply px-3 py-1 rounded-full text-xs font-semibold border;
  }

  .badge-success {
    @apply badge-cyber bg-neon-green/10 text-neon-green border-neon-green/30;
  }

  .badge-warning {
    @apply badge-cyber bg-neon-orange/10 text-neon-orange border-neon-orange/30;
  }

  .badge-info {
    @apply badge-cyber bg-neon-blue/10 text-neon-blue border-neon-blue/30;
  }
}